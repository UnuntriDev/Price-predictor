# Copy to .env and adjust. All variables are PP_-prefixed; nested groups
# use a double underscore (PP_<GROUP>__<FIELD>). Values here are the
# defaults baked into pydantic-settings - override only what you need.

PP_ENV=local

# --- Postgres ---
PP_POSTGRES__HOST=localhost
PP_POSTGRES__PORT=5432
PP_POSTGRES__USER=price_predictor
PP_POSTGRES__PASSWORD=change-me
PP_POSTGRES__DATABASE=price_predictor

# --- MLflow ---
# Local default is SQLite; docker-compose overrides this to the
# Postgres-backed MLflow server at http://mlflow:5000 (see ADR 0003).
PP_MLFLOW__TRACKING_URI=sqlite:///mlflow.db
PP_MLFLOW__EXPERIMENT_NAME=price-predictor

# --- API / serving ---
PP_API__PORT=8000
PP_API__STREAMLIT_PORT=7860
PP_API__MODEL_NAME=price-predictor
PP_API__MODEL_STAGE=production

# --- Scraping (polite-crawl) ---
PP_SCRAPING__MAX_PAGES=50
PP_SCRAPING__DOWNLOAD_DELAY_SECONDS=2.0
PP_SCRAPING__CONCURRENT_REQUESTS=4

# --- Monitoring ---
PP_MONITORING__PROMETHEUS_PORT=9090
PP_MONITORING__DRIFT_P_VALUE_THRESHOLD=0.05

# --- Logging ---
PP_LOGGING__LEVEL=INFO
PP_LOGGING__JSON_OUTPUT=false

# --- Grafana (docker-compose only) ---
GF_ADMIN_PASSWORD=admin

# --- MinIO / DVC remote (docker-compose + ADR 0009) ---
# DVC reads bucket creds from .dvc/config.local (gitignored). The
# compose default dev creds match these; change both for anything real.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
